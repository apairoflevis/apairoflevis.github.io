{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Serve (Static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "-d", "docs"],
      "port": 8000
    }
  ]
}
